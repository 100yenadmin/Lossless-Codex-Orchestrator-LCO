    "rejected_packets": [
      {
        "packet_kind": "CompactionCaptured",
        "source": "codex_native",
        "rejected": true,
        "reason": "raw_replacement_history_present",
        "disallowedFields": [
          "rawReplacementHistory"
        ]
      },
      {
        "packet_kind": "CompactionCaptured",
        "source": "codex_native",
        "rejected": true,
        "reason": "transcript_path_present",
        "disallowedFields": [
          "transcriptPath"
        ]
      }
    ]
